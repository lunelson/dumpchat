{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": [
    "**/*.md",
    "**/*.mdx",
    ".git/**",
    ".output/**",
    ".wxt/**",
    "coverage/**",
    "node_modules/**"
  ],
  "trailingComma": "all",
  "sortImports": {
    "enabled": true,
    "groups": ["builtin", "external", "internal", "parent", "sibling", "index"]
  },
  "sortPackageJson": true,
  "sortTailwindcss": {
    "enabled": true
  }
}
